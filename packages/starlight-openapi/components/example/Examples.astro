---
import type { ExamplesV3 } from '../../libs/example'
import type { Parameter } from '../../libs/parameter'
import ContentPicker from '../ContentPicker.astro'

import Example from './Example.astro'

export interface Props {
  example: unknown | undefined
  examples: ExamplesV3 | undefined
  generated?: boolean | undefined
  parameter?: Parameter | undefined
  type?: string | undefined
}

const { example, examples, generated, parameter, type } = Astro.props
---

{
  example !== undefined || examples ? (
    examples ? (
      <div class="sl-openapi-examples">
        <h5 class="sl-openapi-examples-heading">Examples</h5>
        <ContentPicker label="Select example" types={Object.keys(examples)}>
          {Object.entries(examples).map(([exampleType, data], index) => (
            <div data-openapi-content-type={exampleType} hidden={index > 0} role="tabpanel">
              <Example example={data} {type} />
            </div>
          ))}
        </ContentPicker>
      </div>
    ) : (
      <div class="sl-openapi-examples">
        <h5 class="sl-openapi-examples-heading">
          Example
          {generated && <sup class="sl-openapi-examples-generated">generated</sup>}
        </h5>
        <Example raw={example} {parameter} {type} />
      </div>
    )
  ) : null
}

<style>
  .sl-openapi-examples-heading {
    margin-block: 0.8rem;
  }

  .sl-openapi-examples-generated {
    color: var(--sl-color-text-accent);
    font-size: var(--sl-text-xs);
    font-weight: 400;
    margin-inline-start: 0.1875rem;
    position: relative;
    top: -0.125em;
  }
</style>
