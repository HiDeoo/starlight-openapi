---
import { Code } from '@astrojs/starlight/components'

import type { ExampleV3 } from '../../libs/example'
import { formatParameterValue, formatQueryParameterExample, type Parameter } from '../../libs/parameter'
import Md from '../Md.astro'
import Text from '../Text.astro'

interface Props {
  example?: ExampleV3
  parameter?: Parameter | undefined
  raw?: ExampleV3['value']
  type?: string | undefined
}

const { example, parameter, raw, type } = Astro.props

const exampleToRender = raw === undefined ? example : { value: raw }

function getExampleValue(value: unknown): string {
  return parameter?.in === 'query' ? formatQueryParameterExample(parameter, value) : getFallbackValue(value)
}

function getFallbackValue(value: unknown): string {
  return formatParameterValue(value, true)
}

function getExampleLang(value: unknown, code: string, type: string | undefined) {
  if (typeof value === 'string' && type?.includes('xml')) return 'xml'

  switch (type) {
    case 'application/json': {
      return 'json'
    }
    default: {
      try {
        JSON.parse(code)
        return 'json'
      } catch {
        // Fallback to plain text when failing to parse the code as JSON.
      }
      return 'plaintext'
    }
  }
}

const code = exampleToRender ? getExampleValue(exampleToRender.value).trim() : ''
---

{
  exampleToRender && (
    <div class="sl-openapi-example">
      <Text>{exampleToRender.summary}</Text>
      <Md text={exampleToRender.description} />
      {exampleToRender.externalValue && (
        <Text>
          <a href={exampleToRender.externalValue}>{exampleToRender.externalValue}</a>
        </Text>
      )}
      {code.length > 0 && <Code {code} lang={getExampleLang(exampleToRender.value, code, type)} />}
    </div>
  )
}

<style>
  .sl-openapi-example :global(div.expressive-code .frame pre) {
    background-color: var(--sl-color-gray-5);
    border: 1px solid var(--sl-color-gray-4);
    margin-block: 0.5rem;
  }

  .sl-openapi-example > :global(div.expressive-code:last-child .frame pre) {
    margin-block-end: 0;
  }

  .sl-openapi-example :global(div.expressive-code pre > code) {
    text-wrap: wrap;
    word-break: break-all;
  }
</style>
