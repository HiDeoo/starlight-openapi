---
import { Icon } from '@astrojs/starlight/components'
import context from 'virtual:starlight-openapi/context'

import type { Operation } from '../../libs/operation'
import { getSchemaBaseLink, slug } from '../../libs/path'
import type { Schema } from '../../libs/schemas/schema'
import { getSecurityRequirements } from '../../libs/security'
import Section from '../Section.astro'
import Tags from '../Tags.astro'

interface Props {
  operation: Operation
  schema?: Schema
}

const { operation, schema } = Astro.props

const requirements = getSecurityRequirements(operation, schema)
---

{
  requirements && requirements.length > 0 ? (
    <Section level={2} title="Authorizations">
      <ul class="sl-openapi-security-schemes">
        {requirements.map((requirement) => {
          const schemes = Object.keys(requirement)

          if (schemes.length === 0) {
            return (
              <li class="sl-openapi-security-scheme">
                <Icon name="seti:ignored" />
                <strong>None</strong>
              </li>
            )
          }

          return Object.entries(requirement).map(([scheme, scopes]) => {
            return (
              <li class="sl-openapi-security-scheme not-content">
                <Icon name="seti:lock" />
                <strong>
                  {schema ? (
                    <a href={`${getSchemaBaseLink(schema.config, context)}#${slug(scheme)}`}>{scheme}</a>
                  ) : (
                    scheme
                  )}
                </strong>
                {scopes.length > 0 ? <Tags tags={[...scopes]} /> : null}
              </li>
            )
          })
        })}
      </ul>
    </Section>
  ) : null
}

<style>
  ul.sl-openapi-security-schemes {
    list-style-type: none;
    padding-inline-start: 0;
  }

  .sl-openapi-security-scheme {
    align-items: center;
    column-gap: 0.75rem;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    row-gap: 0.5rem;
  }

  .sl-openapi-security-scheme a {
    color: var(--sl-color-text-accent);
  }

  .sl-openapi-security-scheme a:hover {
    color: var(--sl-color-white);
  }

  .sl-openapi-security-scheme > :global(svg) {
    display: inline;
    flex-shrink: 0;
  }

  .sl-openapi-security-scheme > :global(.sl-openapi-tags) {
    grid-column: 2;
    margin-block: 0;
  }

  @media (min-width: 35rem) {
    .sl-openapi-security-scheme {
      display: flex;
      gap: 0.75rem;
    }
  }
</style>
