---
import { Tabs, TabItem } from '@astrojs/starlight/components'

import { getType } from '../../libs/items'
import { isObjectLike } from '../../libs/predicate'
import type { Discriminator, SchemaObjects, SchemaObject as SchemaObjectType } from '../../libs/schemaObject'
import Tag from '../Tag.astro'

import SchemaObject, { type HideSchemaExampleProps } from './SchemaObject.astro'

interface Props extends HideSchemaExampleProps {
  discriminator: Discriminator
  nested: boolean
  parents?: SchemaObjectType[]
  schemaObjects: SchemaObjects
}

const {
  discriminator,
  hideExample,
  nested,
  parents = [],
  schemaObjects: { schemaObjects, type },
} = Astro.props

const discriminatorPropertyName =
  typeof discriminator === 'string'
    ? discriminator
    : isObjectLike(discriminator)
      ? discriminator.propertyName
      : undefined

const humanReadableType: Record<SchemaObjects['type'], string> = {
  anyOf: 'Any of',
  oneOf: 'One of',
}
---

<div class="sl-openapi-schema-objects">
  <span class="sl-openapi-schema-objects-type">{humanReadableType[type]}:</span>
  {discriminatorPropertyName && <Tag>discriminator: {discriminatorPropertyName}</Tag>}
</div>
<Tabs>
  {
    schemaObjects.map((schemaObject) => (
      <TabItem label={schemaObject.title ?? getType(schemaObject) ?? 'unknown'}>
        <SchemaObject {hideExample} {parents} {nested} schemaObject={schemaObject} />
      </TabItem>
    ))
  }
</Tabs>

<style>
  .sl-openapi-schema-objects {
    margin-bottom: 0.5rem;
  }

  .sl-openapi-schema-objects-type {
    margin-inline-end: 0.3rem;
    text-decoration: underline;
    text-underline-offset: 0.3rem;
  }
</style>
