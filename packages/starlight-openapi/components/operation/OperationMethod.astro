---
import type { OperationHttpMethod } from '../../libs/operation'

import OperationMethodBadge from './OperationMethodBadge.astro'

interface Props {
  method: OperationHttpMethod
  path?: string | undefined
}

const { method, path } = Astro.props
---

<div class="sl-openapi-operation-method">
  <OperationMethodBadge {method} />
  {path && <div class="sl-openapi-operation-method-path">{path}</div>}
</div>

<style>
  .sl-openapi-operation-method {
    align-items: stretch;
    display: flex;
    gap: 0.8rem;
    overflow-x: hidden;
  }

  .sl-openapi-operation-method-path {
    align-items: center;
    display: flex;
    flex-grow: 0;
    flex-shrink: 1;
    overflow-x: auto;
  }
</style>
