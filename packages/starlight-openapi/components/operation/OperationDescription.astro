---
import { Icon } from '@astrojs/starlight/components'

import type { OperationURL, PathItemOperation } from '../../libs/operation'
import type { OperationSnippets as Snippets } from '../../libs/snippet'

import OperationMethod from './OperationMethod.astro'
import OperationSnippetPicker from './OperationSnippetPicker.astro'
import OperationSnippets from './OperationSnippets.astro'
import OperationUrl from './OperationUrl.astro'

interface Props {
  method: PathItemOperation['method']
  snippets?: Snippets | undefined
  path: PathItemOperation['path']
  urls?: OperationURL[]
}

const { method, path, snippets, urls } = Astro.props

const hasOperationUrls = path !== undefined && urls !== undefined && urls.length > 0
const hasOnlyImplicitOperationUrl = urls?.length === 1 && urls[0]?.implicit === true && !urls[0].description
const showOperationUrls = hasOperationUrls && !hasOnlyImplicitOperationUrl
---

<div class="not-content sl-openapi-operation-description">
  <div class="sl-openapi-operation-description-header">
    {
      showOperationUrls && (
        <button
          aria-controls="sl-openapi-operation-description-popover"
          aria-label="Toggle operation URLs"
          class="sl-openapi-operation-description-button"
          popovertarget="sl-openapi-operation-description-popover"
        >
          <Icon class="sl-openapi-operation-description-caret" name="down-caret" />
        </button>
      )
    }
    <OperationMethod {method} {path} />
    {snippets && snippets.items.length > 0 && <OperationSnippetPicker {snippets} />}
  </div>
  {snippets && snippets.items.length > 0 && <OperationSnippets {snippets} />}
</div>

{
  showOperationUrls && (
    <div id="sl-openapi-operation-description-popover" popover>
      <ul class="sl-openapi-operation-description-urls">
        {urls.map(({ description, url }) => (
          <OperationUrl {description} {url} />
        ))}
      </ul>
    </div>
  )
}

<style>
  .sl-openapi-operation-description {
    border: 1px solid var(--sl-color-gray-5);
    border-bottom: none;
    margin-bottom: 2.5rem;
  }

  .sl-openapi-operation-description-header {
    align-items: stretch;
    border-bottom: 1px solid var(--sl-color-gray-5);
    color: var(--sl-color-gray-1);
    display: grid;
    font-family: var(--__sl-font-mono);
    font-size: var(--sl-text-sm);
    grid-template-columns: auto;
    padding: 0.8rem 1rem;
    column-gap: 1rem;
  }

  .sl-openapi-operation-description-header:has(.sl-openapi-operation-description-button) {
    grid-template-columns: min-content auto;
  }

  :global(.sl-openapi-operation-description-header:has(.sl-openapi-snippet-picker)) {
    grid-template-columns: auto min-content;
  }

  :global(
    .sl-openapi-operation-description-header:has(.sl-openapi-operation-description-button):has(
        .sl-openapi-snippet-picker
      )
  ) {
    grid-template-columns: min-content auto min-content;
  }

  .sl-openapi-operation-description-button {
    anchor-name: --sl-openapi-anchor-operation-description-button;

    align-items: center;
    background-color: var(--sl-color-gray-7, var(--sl-color-gray-6));
    border: 1px solid var(--sl-color-gray-4);
    display: flex;
    padding-inline: 0.25rem;
  }

  .sl-openapi-operation-description-button:hover {
    border-color: var(--sl-color-gray-2);

    .sl-openapi-operation-description-caret {
      color: var(--sl-color-gray-1);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .sl-openapi-operation-description-caret {
      transition: transform 0.2s ease-in-out;
    }
  }

  .sl-openapi-operation-description-caret {
    color: var(--sl-color-gray-2);
    font-size: 1.25rem;
  }

  :global(:has([popover]:popover-open)) .sl-openapi-operation-description-caret {
    transform: rotateZ(180deg);
  }

  #sl-openapi-operation-description-popover {
    --sl-openapi-popover-arrow-size: 1rem;
    --sl-openapi-popover-gap: 1.1875rem;

    background: transparent;
    border: none;
    inset-inline-start: calc(anchor(left) - 0.375rem);
    margin: 0;
    overflow: visible;
    padding: 0;
    position-anchor: --sl-openapi-anchor-operation-description-button;
    position: absolute;
    top: calc(anchor(bottom) + var(--sl-openapi-popover-gap));

    &::before {
      background-color: var(--sl-color-bg);
      border-left: 1px solid var(--sl-color-gray-4);
      border-top: 1px solid var(--sl-color-gray-4);
      content: '';
      height: var(--sl-openapi-popover-arrow-size);
      inset-inline-start: 1rem;
      position: absolute;
      top: 0;
      transform: translateY(-50%) rotate(45deg);
      width: var(--sl-openapi-popover-arrow-size);
    }
  }

  .sl-openapi-operation-description-urls {
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-gray-4);
    box-shadow: var(--sl-shadow-md);
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    list-style-type: none;
    padding: 0.8rem;
  }
</style>
