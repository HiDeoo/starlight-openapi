---
import { Code, Tabs, TabItem } from '@astrojs/starlight/components'

interface CodeSample {
  lang: string
  label: string
  source: string
}

interface Props {
  operation: any
}

const { operation } = Astro.props

const codeSamples = (operation['x-codeSamples'] ?? []) as CodeSample[]
---

{
  codeSamples.length > 0 && (
    <Tabs>
      {codeSamples.map((sample) => (
        <TabItem label={sample.label}>
          <Code code={sample.source} lang={sample.lang} />
        </TabItem>
      ))}
    </Tabs>
  )
}
