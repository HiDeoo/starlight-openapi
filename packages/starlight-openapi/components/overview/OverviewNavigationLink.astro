---
import { Icon } from '@astrojs/starlight/components'

import type { OperationHttpMethod } from '../../libs/operation'
import OperationMethodBadge from '../operation/OperationMethodBadge.astro'
import Tag from '../Tag.astro'

interface Props {
  href: string
  isWebhook: boolean
  label: string
  method: OperationHttpMethod
}

const { href, isWebhook, label, method } = Astro.props
---

<div class="sl-openapi-overview-navigation-link">
  <OperationMethodBadge {method} />
  <span class="sl-openapi-overview-navigation-link-content">
    <a {href}>{label}</a>
    {isWebhook && <Tag>WEBHOOK</Tag>}
  </span>
  <Icon name="right-arrow" size="1.333em" class="sl-openapi-overview-navigation-link-icon rtl:flip" />
</div>

<style>
  .sl-openapi-overview-navigation-link {
    align-items: start;
    border: 1px solid var(--sl-color-gray-5);
    box-shadow: var(--sl-shadow-sm);
    column-gap: inherit;
    display: grid;
    grid-column: 1 / -1;
    grid-template-columns: subgrid;
    padding: 0.875rem;
    position: relative;
  }

  .sl-openapi-overview-navigation-link :global(.sl-openapi-operation-method-badge) {
    justify-self: end;
    width: max-content;
  }

  .sl-openapi-overview-navigation-link-content {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    min-width: 0;
  }

  .sl-openapi-overview-navigation-link a {
    color: var(--sl-color-gray-1);
    font-family: var(--__sl-font-mono);
    font-size: var(--sl-text-sm);
    justify-self: start;
    overflow-wrap: anywhere;
    text-decoration: none;
  }

  .sl-openapi-overview-navigation-link a::before {
    content: '';
    inset: 0;
    position: absolute;
  }

  .sl-openapi-overview-navigation-link-icon {
    color: var(--sl-color-gray-3);
  }

  .sl-openapi-overview-navigation-link:is(:hover, :focus-within) {
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
    border-color: var(--sl-color-gray-2);
  }

  .sl-openapi-overview-navigation-link:is(:hover, :focus-within) .sl-openapi-overview-navigation-link-icon {
    color: var(--sl-color-white);
  }
</style>
