---
import { Badge, Card } from '@astrojs/starlight/components'
import context from 'virtual:starlight-openapi/context'

import { getOpenAPIVersion, getSummary } from '../../libs/document'
import { getSchemaNavigationGroups } from '../../libs/pathItem'
import type { Schema } from '../../libs/schemas/schema'
import { getSecurityDefinitions } from '../../libs/security'
import ExternalDocs from '../ExternalDocs.astro'
import Heading from '../Heading.astro'
import Md from '../Md.astro'
import SecurityDefinitions from '../security/SecurityDefinitions.astro'
import Text from '../Text.astro'

import OverviewNavigationLinks from './OverviewNavigationLinks.astro'

interface Props {
  schema: Schema
}

const { schema } = Astro.props
const { document } = schema

const summary = getSummary(document)
const securityDefinitions = getSecurityDefinitions(document)
const contacts = [
  document.info.contact?.url && { href: document.info.contact.url, label: document.info.contact.url },
  document.info.contact?.email && { href: `mailto:${document.info.contact.email}`, label: document.info.contact.email },
].filter((contact): contact is { href: string; label: string } => !!contact)
---

<Text>{summary}</Text>

<Heading level={2} id="overview">{document.info.title}{' '}<Badge size="large" text={document.info.version} /></Heading>

<Md text={document.info.description} />
<ExternalDocs docs={document.externalDocs} />

<div class="sl-openapi-overview-meta">
  {
    contacts.length > 0 && (
      <Card icon="external" title={document.info.contact?.name ?? 'Contact'}>
        <ul>
          {contacts.map((contact) => (
            <li>
              <a href={contact.href}>{contact.label}</a>
            </li>
          ))}
        </ul>
      </Card>
    )
  }
  <Card icon="information" title="Informations">
    <ul>
      {
        document.info.termsOfService && (
          <li>
            <a href={document.info.termsOfService}>Terms of Service</a>
          </li>
        )
      }
      {
        document.info.license && (
          <li>
            License:{' '}
            {document.info.license.url ? (
              <a href={document.info.license.url}>{document.info.license.name}</a>
            ) : (
              document.info.license.name
            )}
          </li>
        )
      }
      <li>OpenAPI version: <code>{getOpenAPIVersion(document)}</code></li>
    </ul>
  </Card>
</div>

<OverviewNavigationLinks groups={getSchemaNavigationGroups(schema, context)} />

<SecurityDefinitions definitions={securityDefinitions} />

<style>
  .sl-openapi-overview-meta :global(.card) {
    padding: clamp(1rem, calc(0.125rem + 3vw), 2rem);
  }

  .sl-openapi-overview-meta :global(.card ul) {
    margin-block-start: 0.5rem;
    padding-inline-start: 1.75rem;
  }
</style>
