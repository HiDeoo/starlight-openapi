---
import type { SchemaNavigationGroup } from '../../libs/pathItem'
import Heading from '../Heading.astro'

import OverviewNavigationLink from './OverviewNavigationLink.astro'

interface Props {
  groups: SchemaNavigationGroup[]
}

const { groups } = Astro.props

const visibleGroups = groups.filter((group) => group.links.length > 0)
---

{
  visibleGroups.length > 0 && (
    <div class="sl-openapi-overview-navigation">
      <Heading level={2} id="operations">
        Operations
      </Heading>
      <div class="sl-openapi-overview-navigation-links not-content">
        {visibleGroups.map((group) =>
          group.links.map((link) => (
            <OverviewNavigationLink
              href={link.href}
              isWebhook={link.path === undefined}
              label={link.path ?? link.label}
              method={link.method}
            />
          )),
        )}
      </div>
    </div>
  )
}

<style>
  .sl-openapi-overview-navigation {
    margin-top: 3.25rem;
  }

  .sl-openapi-overview-navigation-links {
    column-gap: 0.75rem;
    display: grid;
    font-size: var(--sl-text-xs);
    grid-template-columns: max-content minmax(0, 1fr) auto;
    row-gap: 0.625rem;
  }
</style>
